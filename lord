local function Tween(inst, props, t, style, dir)
	t     = t     or 0.18
	style = style or Enum.EasingStyle.Quart
	dir   = dir   or Enum.EasingDirection.Out
	TweenService:Create(inst, TI(t, style, dir), props):Play()
end

local function MakeCorner(parent, radius)
	local c = New("UICorner")
	c.CornerRadius = UD(0, radius or 6)
	c.Parent = parent
end

local function MakePadding(parent, t, b, l, r)
	local p = New("UIPadding")
	p.PaddingTop    = UD(0, t or 0)
	p.PaddingBottom = UD(0, b or 0)
	p.PaddingLeft   = UD(0, l or 0)
	p.PaddingRight  = UD(0, r or 0)
	p.Parent = parent
end

local function MakeStroke(parent, color, thickness, mode)
	local s = New("UIStroke")
	s.Color            = color or C3(30, 34, 34)
	s.Thickness        = thickness or 1
	s.ApplyStrokeMode  = mode or Enum.ApplyStrokeMode.Border
	s.Parent           = parent
	return s
end

local function MakeList(parent, padding, fill, halign)
	local l = New("UIListLayout")
	l.Padding             = UD(0, padding or 8)
	l.SortOrder           = Enum.SortOrder.LayoutOrder
	l.FillDirection       = fill   or Enum.FillDirection.Vertical
	l.HorizontalAlignment = halign or Enum.HorizontalAlignment.Left
	l.Parent = parent
	return l
end

