		Tween(overlay, {BackgroundTransparency = 1}, 0.15)
		task.wait(0.16)
		overlay:Destroy()
		self._ModalOverlay = nil
	end

	local function HandleInput(btn, fn)
		Connect(btn.MouseButton1Click, fn)
		Connect(btn.InputBegan, function(i)
			if i.UserInputType == Enum.UserInputType.Touch then fn() end
		end)
	end

	HandleInput(CancelBtn, CloseModal)
	HandleInput(ConfirmBtn, function()
		if self.OnSave then self:OnSave() end
		for flag, val in self.Flags do
			if val == true then
				local fn = self.SetFlags[flag]
				if fn then pcall(fn, false) end
			end
		end
		CloseModal()
		self:Notification("Saved & unloaded.", 3)
		task.delay(0.6, function() self:Destroy() end)
	end)
