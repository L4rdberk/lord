				ValueLabel.FontFace  = Font
				ValueLabel.TextSize  = 11
				ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
				ValueLabel.Parent    = TopRow

				local TrackFrame = New("Frame")
				TrackFrame.Size      = U2(1, 0, 0, 4)
				TrackFrame.Position  = U2(0, 0, 1, 8)
				TrackFrame.AnchorPoint = V2(0, 0)
				TrackFrame.BackgroundColor3 = sp._lib.Theme.Element
				TrackFrame.BorderSizePixel = 0
				TrackFrame.Parent    = Wrap
				MakeCorner(TrackFrame, 3)

				local pct0 = (default - min) / (max - min)

				local Fill = New("Frame")
				Fill.Size            = U2(pct0, 0, 1, 0)
				Fill.BackgroundColor3= C3(120, 120, 120)
				Fill.BorderSizePixel = 0
				Fill.Parent          = TrackFrame
				MakeCorner(Fill, 3)

				local Thumb = New("Frame")
				Thumb.Size           = U2(0, 9, 0, 9)
				Thumb.Position       = U2(pct0, -4, 0.5, -4)
				Thumb.AnchorPoint    = V2(0, 0)
				Thumb.BackgroundColor3 = C3(208, 208, 208)
				Thumb.BorderSizePixel= 0
				Thumb.Parent         = TrackFrame
				MakeCorner(Thumb, 99)

				local HitBtn = New("TextButton")
				HitBtn.Size          = U2(1, 0, 0, 18)
				HitBtn.Position      = U2(0, 0, 0.5, -9)
				HitBtn.BackgroundTransparency = 1
				HitBtn.Text          = ""
				HitBtn.AutoButtonColor= false
				HitBtn.Parent        = TrackFrame

				local sliding = false

				local function SlideFromInput(inputPos)
					local abs  = TrackFrame.AbsolutePosition
					local size = TrackFrame.AbsoluteSize
					local pct  = math.clamp((inputPos.X - abs.X) / size.X, 0, 1)
					local v    = min + (max - min) * pct
					sp._lib.SetFlags[flag](v)
				end

				Connect(HitBtn.InputBegan, function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
						sliding = true
						SlideFromInput(V2(i.Position.X, i.Position.Y))
					end
				end)
				Connect(UserInputService.InputChanged, function(i)
					if not sliding then return end
					if i.UserInputType == Enum.UserInputType.MouseMovement
					or i.UserInputType == Enum.UserInputType.Touch then
						SlideFromInput(V2(i.Position.X, i.Position.Y))
					end
				end)
				Connect(UserInputService.InputEnded, function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
						sliding = false
					end
				end)

				return {
					SetValue = function(_, v) sp._lib.SetFlags[flag](v) end,
					GetValue = function() return value end,
				}
			end

			function SecMeta:Dropdown(dData)
				dData    = dData or {}
				local flag     = dData.Flag  or tostring(math.random(1e9))
				local items    = dData.Items or {}
				local default  = dData.Default or (items[1] or "")
				local multi    = dData.Multi or false
				local callback = dData.Callback or function() end
				local selected = multi and {} or default

				sp._lib.Flags[flag]    = selected
				sp._lib.SetFlags[flag] = function(v)
					selected = v
					sp._lib.Flags[flag] = v
					if not multi then
						SelectedLabel.Text = tostring(v)
					else
						SelectedLabel.Text = next(v) and table.concat(v, ", ") or "None"
					end
					pcall(callback, v)
				end

				local Wrap = New("Frame")
				Wrap.Size            = U2(1, 0, 0, 25)
				Wrap.BackgroundTransparency = 1
				Wrap.BorderSizePixel = 0
