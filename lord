	local ActiveFlags = {}
	local FlagNames = {
		Aimbot_Enable      = "Aimbot",
		Aimbot_SilentAim   = "Silent Aim",
		Aimbot_AutoFire    = "Auto Fire",
		Prediction_Enable  = "Prediction",
		Weapon_RapidFire   = "Rapid Fire",
		Weapon_NoSpread    = "No Spread",
		Esp_Enable         = "ESP",
		Watermark_Enable   = "Watermark",
		Player_NoClip      = "No Clip",
		World_FullBright   = "Full Bright",
	}
	for flag, label in FlagNames do
		if self.Flags[flag] == true then
			table.insert(ActiveFlags, label)
