				local SelectedLabel = New("TextLabel")
				SelectedLabel.Size   = U2(1, -18, 1, 0)
				SelectedLabel.BackgroundTransparency = 1
				SelectedLabel.Text   = not multi and tostring(default) or "None"
				SelectedLabel.TextColor3 = sp._lib.Theme.TextDim
				SelectedLabel.FontFace   = Font
				SelectedLabel.TextSize   = 12
				SelectedLabel.TextXAlignment = Enum.TextXAlignment.Left
				SelectedLabel.Parent = BtnFrame

				local ArrowLabel = New("TextLabel")
				ArrowLabel.Size      = U2(0, 14, 1, 0)
				ArrowLabel.Position  = U2(1, -14, 0, 0)
				ArrowLabel.BackgroundTransparency = 1
				ArrowLabel.Text      = "▼"
				ArrowLabel.TextColor3= sp._lib.Theme.TextDim
				ArrowLabel.FontFace  = Font
				ArrowLabel.TextSize  = 9
				ArrowLabel.Parent    = BtnFrame

				local DropFrame = New("Frame")
				DropFrame.Size       = U2(1, 0, 0, 0)
				DropFrame.AutomaticSize = Enum.AutomaticSize.Y
				DropFrame.BackgroundColor3 = sp._lib.Theme.Section
				DropFrame.BorderSizePixel = 0
				DropFrame.Visible    = false
				DropFrame.ZIndex     = 10
				DropFrame.Parent     = sp._lib._OverlayGui
				MakeCorner(DropFrame, 6)
				MakeStroke(DropFrame, sp._lib.Theme.Border2, 1)

				local isOpen = false
				local function CloseDropdown()
					isOpen = false
					DropFrame.Visible = false
					ArrowLabel.Text   = "▼"
				end
				local function OpenDropdown()
					isOpen = true
					local abs  = BtnFrame.AbsolutePosition
					local size = BtnFrame.AbsoluteSize
					DropFrame.Position = U2(0, abs.X, 0, abs.Y + size.Y + 4)
					DropFrame.Size     = U2(0, size.X, 0, 0)
					DropFrame.Visible  = true
					ArrowLabel.Text    = "▲"
				end

				for _, item in items do
					local Opt = New("TextButton")
					Opt.Size           = U2(1, 0, 0, 28)
					Opt.BackgroundTransparency = 1
					Opt.BorderSizePixel= 0
					Opt.Text           = ""
					Opt.AutoButtonColor= false
					Opt.ZIndex         = 11
					Opt.Parent         = DropFrame
					MakePadding(Opt, 0, 0, 10, 10)

					local OptLabel = New("TextLabel")
					OptLabel.Size      = U2(1, 0, 1, 0)
					OptLabel.BackgroundTransparency = 1
					OptLabel.Text      = tostring(item)
					OptLabel.TextColor3= sp._lib.Theme.TextDim
					OptLabel.FontFace  = Font
					OptLabel.TextSize  = 12
					OptLabel.TextXAlignment = Enum.TextXAlignment.Left
					OptLabel.ZIndex    = 11
					OptLabel.Parent    = Opt

					local function Select()
						if not multi then
							sp._lib.SetFlags[flag](item)
							CloseDropdown()
						else
							local idx = table.find(selected, item)
							if idx then
								table.remove(selected, idx)
								Tween(OptLabel, {TextColor3 = sp._lib.Theme.TextDim}, 0.12)
							else
								table.insert(selected, item)
								Tween(OptLabel, {TextColor3 = sp._lib.Theme.Text}, 0.12)
							end
							sp._lib.Flags[flag] = selected
							SelectedLabel.Text  = #selected > 0 and table.concat(selected, ", ") or "None"
							pcall(callback, selected)
						end
					end
					Connect(Opt.MouseButton1Click, Select)
					Connect(Opt.InputBegan, function(i)
						if i.UserInputType == Enum.UserInputType.Touch then Select() end
					end)
					Connect(Opt.MouseEnter, function()
						Tween(Opt, {BackgroundTransparency = 0.85}, 0.1)
						Opt.BackgroundColor3 = sp._lib.Theme.Element
					end)
					Connect(Opt.MouseLeave, function()
						Tween(Opt, {BackgroundTransparency = 1}, 0.1)
					end)
				end

				MakeList(DropFrame, 0)

				local function ToggleDrop()
					if isOpen then CloseDropdown() else OpenDropdown() end
				end
				Connect(BtnFrame.MouseButton1Click, ToggleDrop)
				Connect(BtnFrame.InputBegan, function(i)
					if i.UserInputType == Enum.UserInputType.Touch then ToggleDrop() end
				end)
				Connect(UserInputService.InputBegan, function(i)
					if not isOpen then return end
					if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
						local mpos = V2(i.Position.X, i.Position.Y)
						local apos = DropFrame.AbsolutePosition
						local asize= DropFrame.AbsoluteSize
						if mpos.X < apos.X or mpos.X > apos.X + asize.X
						or mpos.Y < apos.Y or mpos.Y > apos.Y + asize.Y then
							CloseDropdown()
						end
					end
				end)

				return {
					Refresh = function(_, newItems)
						for _, child in DropFrame:GetChildren() do
							if child:IsA("TextButton") then child:Destroy() end
						end
						for _, item in newItems do
							local Opt = New("TextButton")
							Opt.Size           = U2(1, 0, 0, 28)
							Opt.BackgroundTransparency = 1
							Opt.BorderSizePixel= 0
							Opt.Text           = ""
							Opt.AutoButtonColor= false
							Opt.ZIndex         = 11
							Opt.Parent         = DropFrame
							MakePadding(Opt, 0, 0, 10, 10)
							local OL = New("TextLabel")
							OL.Size            = U2(1, 0, 1, 0)
							OL.BackgroundTransparency = 1
							OL.Text            = tostring(item)
							OL.TextColor3      = sp._lib.Theme.TextDim
							OL.FontFace        = Font
							OL.TextSize        = 12
							OL.TextXAlignment  = Enum.TextXAlignment.Left
							OL.ZIndex          = 11
							OL.Parent          = Opt
						end
					end,
					GetValue = function() return selected end,
				}
			end

			function SecMeta:Button(bData)
				bData    = bData or {}
				local callback = bData.Callback or function() end

				local Btn = New("TextButton")
				Btn.Size           = U2(1, 0, 0, 26)
				Btn.BackgroundColor3 = sp._lib.Theme.Element
				Btn.BorderSizePixel= 0
				Btn.Text           = bData.Name or "Button"
				Btn.TextColor3     = sp._lib.Theme.Text
				Btn.FontFace       = Font
				Btn.TextSize       = 12
				Btn.AutoButtonColor= false
				Btn.Parent         = ContentFrame
				MakeCorner(Btn, 5)
				MakeStroke(Btn, sp._lib.Theme.Border2, 1)

				local function Press()
					Tween(Btn, {BackgroundColor3 = sp._lib.Theme.Accent, TextColor3 = C3(0,0,0)}, 0.08)
					task.delay(0.12, function()
						Tween(Btn, {BackgroundColor3 = sp._lib.Theme.Element, TextColor3 = sp._lib.Theme.Text}, 0.12)
					end)
					pcall(callback)
				end
				Connect(Btn.MouseButton1Click, Press)
				Connect(Btn.InputBegan, function(i)
					if i.UserInputType == Enum.UserInputType.Touch then Press() end
				end)
				Connect(Btn.MouseEnter, function()
					Tween(Btn, {BackgroundColor3 = sp._lib.Theme.Border2}, 0.12)
				end)
				Connect(Btn.MouseLeave, function()
					Tween(Btn, {BackgroundColor3 = sp._lib.Theme.Element}, 0.12)
				end)
			end

			function SecMeta:Label(text)
				local Row = New("Frame")
				Row.Size             = U2(1, 0, 0, 24)
				Row.BackgroundTransparency = 1
				Row.BorderSizePixel  = 0
				Row.Parent           = ContentFrame

				local Lbl = New("TextLabel")
