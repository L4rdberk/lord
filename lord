end

local function MakeDraggable(frame, handle)
	handle = handle or frame
	local dragging, dragStart, startPos = false, nil, nil

	local function BeginDrag(pos)
		dragging  = true
		dragStart = pos
		startPos  = frame.Position
	end
	local function UpdateDrag(pos)
		if not dragging then return end
		local delta = pos - dragStart
		frame.Position = U2(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
	local function EndDrag()
		dragging = false
	end

	Connect(handle.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			BeginDrag(V2(input.Position.X, input.Position.Y))
		end
	end)
	Connect(UserInputService.InputChanged, function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then
			UpdateDrag(V2(input.Position.X, input.Position.Y))
		end
	end)
	Connect(UserInputService.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			EndDrag()
		end
	end)
end

function Library:Destroy()
	for _, c in self.Connections do
		pcall(function() c:Disconnect() end)
	end
	for _, t in self.Threads do
		pcall(function() task.cancel(t) end)
	end
	if self._ScreenGui then
		self._ScreenGui:Destroy()
	end
	if self._OverlayGui then
		self._OverlayGui:Destroy()
	end
	getgenv().AscendLib = nil
end

function Library:Notification(Text, Duration)
	Duration = Duration or 3
	local holder = self._NotifHolder
	if not holder then return end

	local notif = New("Frame")
	notif.Size            = U2(0, 0, 0, 30)
	notif.AutomaticSize   = Enum.AutomaticSize.X
	notif.BackgroundColor3= self.Theme.Section
	notif.BorderSizePixel = 0
	notif.BackgroundTransparency = 1
	notif.Parent          = holder
	MakeCorner(notif, 7)
	MakeStroke(notif, self.Theme.Border, 1)
	MakePadding(notif, 0, 0, 10, 10)

	local label = New("TextLabel")
	label.Size              = U2(0, 0, 1, 0)
	label.AutomaticSize     = Enum.AutomaticSize.X
	label.BackgroundTransparency = 1
	label.Text              = Text
	label.TextColor3        = self.Theme.Text
	label.FontFace          = Font
	label.TextSize          = 13
	label.TextTransparency  = 1
	label.Parent            = notif

	Tween(notif,  {BackgroundTransparency = 0}, 0.3)
	Tween(label, {TextTransparency = 0}, 0.3)

	task.delay(Duration, function()
		Tween(notif,  {BackgroundTransparency = 1}, 0.3)
		Tween(label, {TextTransparency = 1}, 0.3)
		task.wait(0.35)
		notif:Destroy()
	end)
end

