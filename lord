				Lbl.TextXAlignment   = Enum.TextXAlignment.Left
				Lbl.Parent           = Row

				local SubFrame = New("Frame")
				SubFrame.Size        = U2(0, 80, 1, 0)
				SubFrame.Position    = U2(1, -80, 0, 0)
				SubFrame.BackgroundTransparency = 1
				SubFrame.BorderSizePixel = 0
				SubFrame.Parent      = Row
				MakeList(SubFrame, 6, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Right)

				local LabelMeta = {}
