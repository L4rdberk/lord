				function LabelMeta:Colorpicker(cpData)
					cpData   = cpData or {}
					local flag     = cpData.Flag or tostring(math.random(1e9))
					local default  = cpData.Default or C3(255,255,255)
					local callback = cpData.Callback or function() end
					local color    = default

					sp._lib.Flags[flag]    = color
					sp._lib.SetFlags[flag] = function(v)
						color = v
						sp._lib.Flags[flag] = v
						Swatch.BackgroundColor3 = v
						pcall(callback, v)
					end

					local Swatch = New("TextButton")
					Swatch.Size          = U2(0, 22, 0, 22)
					Swatch.AnchorPoint   = V2(0, 0.5)
					Swatch.Position      = U2(0, 0, 0.5, -11)
					Swatch.BackgroundColor3 = color
					Swatch.BorderSizePixel = 0
					Swatch.Text          = ""
					Swatch.AutoButtonColor = false
					Swatch.Parent        = SubFrame
					MakeCorner(Swatch, 4)
					MakeStroke(Swatch, sp._lib.Theme.Border2, 1)

					local cpOpen = false
					local CpFrame = New("Frame")
					CpFrame.Size         = U2(0, 188, 0, 210)
					CpFrame.BackgroundColor3 = sp._lib.Theme.Section
					CpFrame.BorderSizePixel = 0
					CpFrame.Visible      = false
					CpFrame.ZIndex       = 20
					CpFrame.Parent       = sp._lib._OverlayGui
					MakeCorner(CpFrame, 8)
					MakeStroke(CpFrame, sp._lib.Theme.Border2, 1)
					MakePadding(CpFrame, 10, 10, 10, 10)
					MakeList(CpFrame, 8)

					local PaletteFrame = New("ImageButton")
					PaletteFrame.Size    = U2(1, 0, 0, 110)
					PaletteFrame.BackgroundColor3 = C3(255,0,0)
					PaletteFrame.BorderSizePixel = 0
					PaletteFrame.Image   = "rbxassetid://0"
					PaletteFrame.AutoButtonColor = false
					PaletteFrame.ZIndex  = 21
					PaletteFrame.Parent  = CpFrame
					MakeCorner(PaletteFrame, 5)

					local SatGrad = New("UIGradient")
					SatGrad.Color    = ColorSequence.new({
						ColorSequenceKeypoint.new(0, C3(255,255,255)),
						ColorSequenceKeypoint.new(1, C3(255,255,255)),
					})
					SatGrad.Transparency = NumberSequence.new({
						NumberSequenceKeypoint.new(0, 0),
						NumberSequenceKeypoint.new(1, 1),
					})
					SatGrad.Rotation  = 0
					SatGrad.Parent    = PaletteFrame

					local ValGrad = New("Frame")
					ValGrad.Size     = U2(1, 0, 1, 0)
					ValGrad.BackgroundColor3 = C3(0,0,0)
					ValGrad.BackgroundTransparency = 0
					ValGrad.BorderSizePixel = 0
					ValGrad.ZIndex   = 22
					ValGrad.Parent   = PaletteFrame
					MakeCorner(ValGrad, 5)
					local VG = New("UIGradient")
					VG.Color         = ColorSequence.new(C3(0,0,0))
					VG.Transparency  = NumberSequence.new({
						NumberSequenceKeypoint.new(0, 1),
						NumberSequenceKeypoint.new(1, 0),
					})
					VG.Rotation      = 90
					VG.Parent        = ValGrad

					local PaletteDragger = New("Frame")
					PaletteDragger.Size  = U2(0, 8, 0, 8)
					PaletteDragger.AnchorPoint = V2(0.5, 0.5)
					PaletteDragger.Position = U2(1, 0, 0, 0)
					PaletteDragger.BackgroundColor3 = C3(255,255,255)
					PaletteDragger.BorderSizePixel = 0
					PaletteDragger.ZIndex = 23
					PaletteDragger.Parent = PaletteFrame
					MakeCorner(PaletteDragger, 99)
					MakeStroke(PaletteDragger, C3(120,120,120), 1)

					local HueFrame = New("Frame")
					HueFrame.Size    = U2(1, 0, 0, 12)
					HueFrame.BackgroundColor3 = C3(255,255,255)
					HueFrame.BorderSizePixel = 0
					HueFrame.ZIndex  = 21
					HueFrame.Parent  = CpFrame
					MakeCorner(HueFrame, 6)
					local HG = New("UIGradient")
					HG.Color         = ColorSequence.new({
						ColorSequenceKeypoint.new(0/6, C3(255,0,0)),
						ColorSequenceKeypoint.new(1/6, C3(255,255,0)),
						ColorSequenceKeypoint.new(2/6, C3(0,255,0)),
						ColorSequenceKeypoint.new(3/6, C3(0,255,255)),
						ColorSequenceKeypoint.new(4/6, C3(0,0,255)),
						ColorSequenceKeypoint.new(5/6, C3(255,0,255)),
						ColorSequenceKeypoint.new(6/6, C3(255,0,0)),
					})
					HG.Parent = HueFrame

					local HueThumb = New("Frame")
					HueThumb.Size    = U2(0, 8, 0, 8)
					HueThumb.AnchorPoint = V2(0.5, 0.5)
					HueThumb.Position= U2(0, 0, 0.5, 0)
					HueThumb.BackgroundColor3 = C3(255,255,255)
					HueThumb.BorderSizePixel = 0
					HueThumb.ZIndex  = 22
					HueThumb.Parent  = HueFrame
					MakeCorner(HueThumb, 99)
					MakeStroke(HueThumb, C3(160,160,160), 1)

					local HitHue = New("TextButton")
					HitHue.Size      = U2(1, 0, 1, 0)
					HitHue.BackgroundTransparency = 1
					HitHue.Text      = ""
					HitHue.AutoButtonColor = false
					HitHue.ZIndex    = 23
					HitHue.Parent    = HueFrame

					local HexRow = New("Frame")
					HexRow.Size      = U2(1, 0, 0, 22)
					HexRow.BackgroundTransparency = 1
					HexRow.ZIndex    = 21
					HexRow.Parent    = CpFrame

					local HexBox = New("TextBox")
					HexBox.Size      = U2(1, -30, 1, 0)
					HexBox.Position  = U2(0, 30, 0, 0)
					HexBox.BackgroundColor3 = sp._lib.Theme.Element
					HexBox.BorderSizePixel = 0
					HexBox.Text      = ""
					HexBox.TextColor3= sp._lib.Theme.Text
					HexBox.FontFace  = Font
					HexBox.TextSize  = 11
					HexBox.ZIndex    = 22
					HexBox.Parent    = HexRow
					MakeCorner(HexBox, 4)
					MakeStroke(HexBox, sp._lib.Theme.Border2, 1)
					MakePadding(HexBox, 0, 0, 6, 6)

					local PreviewSwatch = New("Frame")
					PreviewSwatch.Size = U2(0, 22, 0, 22)
					PreviewSwatch.BackgroundColor3 = color
					PreviewSwatch.BorderSizePixel = 0
					PreviewSwatch.ZIndex = 22
					PreviewSwatch.Parent = HexRow
					MakeCorner(PreviewSwatch, 4)

					local cpHue = 0
					local cpSat = 1
					local cpVal = 1

					local function HSVtoColor(h, s, v)
						return Color3.fromHSV(h, s, v)
					end
					local function UpdateFromHSV()
						local newColor = HSVtoColor(cpHue, cpSat, cpVal)
						Swatch.BackgroundColor3    = newColor
						PreviewSwatch.BackgroundColor3 = newColor
						PaletteFrame.BackgroundColor3  = Color3.fromHSV(cpHue, 1, 1)
						HexBox.Text = "#" .. string.format("%02X%02X%02X",
							math.floor(newColor.R*255),
							math.floor(newColor.G*255),
							math.floor(newColor.B*255))
						color = newColor
						sp._lib.Flags[flag] = newColor
						pcall(callback, newColor)
					end

					local function SetHueFromX(x)
						local abs  = HueFrame.AbsolutePosition
						local size = HueFrame.AbsoluteSize
						local pct  = math.clamp((x - abs.X) / size.X, 0, 1)
						cpHue      = pct
						HueThumb.Position = U2(pct, -4, 0.5, 0)
						UpdateFromHSV()
					end
					local function SetSVFromXY(x, y)
						local abs  = PaletteFrame.AbsolutePosition
						local size = PaletteFrame.AbsoluteSize
						cpSat = math.clamp((x - abs.X) / size.X, 0, 1)
						cpVal = 1 - math.clamp((y - abs.Y) / size.Y, 0, 1)
						local px = math.clamp((x - abs.X) / size.X, 0, 1)
						local py = math.clamp((y - abs.Y) / size.Y, 0, 1)
						PaletteDragger.Position = U2(px, 0, py, 0)
						UpdateFromHSV()
					end

					local hueSli, palSli = false, false
					Connect(HitHue.InputBegan, function(i)
						if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then
							hueSli = true
							SetHueFromX(i.Position.X)
						end
					end)
					Connect(PaletteFrame.InputBegan, function(i)
						if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then
							palSli = true
							SetSVFromXY(i.Position.X, i.Position.Y)
						end
					end)
					Connect(UserInputService.InputChanged, function(i)
						if i.UserInputType == Enum.UserInputType.MouseMovement
						or i.UserInputType == Enum.UserInputType.Touch then
							if hueSli then SetHueFromX(i.Position.X) end
							if palSli then SetSVFromXY(i.Position.X, i.Position.Y) end
						end
					end)
					Connect(UserInputService.InputEnded, function(i)
						if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then
							hueSli = false
							palSli = false
						end
					end)
					Connect(HexBox.FocusLost, function()
						local hex = HexBox.Text:gsub("#", "")
						if #hex == 6 then
							local r = tonumber(hex:sub(1,2), 16)
							local g = tonumber(hex:sub(3,4), 16)
							local b = tonumber(hex:sub(5,6), 16)
							if r and g and b then
								local c = C3(r, g, b)
								local h2, s2, v2 = Color3.toHSV(c)
								cpHue, cpSat, cpVal = h2, s2, v2
								UpdateFromHSV()
							end
						end
					end)

					local function ToggleCp()
						cpOpen = not cpOpen
						if cpOpen then
							local abs  = Swatch.AbsolutePosition
							local off  = 28
							CpFrame.Position = U2(0, abs.X - 188 - 6, 0, abs.Y)
							if CpFrame.AbsolutePosition.X < 0 then
								CpFrame.Position = U2(0, abs.X + off, 0, abs.Y)
							end
							CpFrame.Visible = true
						else
							CpFrame.Visible = false
						end
					end
					Connect(Swatch.MouseButton1Click, ToggleCp)
					Connect(Swatch.InputBegan, function(i)
						if i.UserInputType == Enum.UserInputType.Touch then ToggleCp() end
					end)
					Connect(UserInputService.InputBegan, function(i)
						if not cpOpen then return end
						if i.UserInputType == Enum.UserInputType.MouseButton1
						or i.UserInputType == Enum.UserInputType.Touch then
							local mpos = V2(i.Position.X, i.Position.Y)
							local apos = CpFrame.AbsolutePosition
							local asize= CpFrame.AbsoluteSize
							if mpos.X < apos.X or mpos.X > apos.X + asize.X
							or mpos.Y < apos.Y or mpos.Y > apos.Y + asize.Y then
								cpOpen = false
								CpFrame.Visible = false
							end
						end
					end)

					cpHue, cpSat, cpVal = Color3.toHSV(default)
					UpdateFromHSV()

					return self
				end

				function LabelMeta:Keybind(kbData)
					kbData   = kbData or {}
					local flag     = kbData.Flag or tostring(math.random(1e9))
					local default  = kbData.Default or Enum.KeyCode.Unknown
					local mode     = kbData.Mode or "Toggle"
					local callback = kbData.Callback or function() end
					local key      = default
					local toggled  = false
					local picking  = false

					sp._lib.Flags[flag]    = {Key = key, Mode = mode, Toggled = toggled}
					sp._lib.SetFlags[flag] = function(v)
						if typeof(v) == "table" then
							key     = v.Key  or key
							mode    = v.Mode or mode
						end
						KeyBtn.Text   = "[" .. tostring(key.Name or key):sub(1, 6) .. "]"
						sp._lib.Flags[flag] = {Key = key, Mode = mode, Toggled = toggled}
					end

					local KeyBtn = New("TextButton")
					KeyBtn.Size          = U2(0, 0, 1, 0)
					KeyBtn.AutomaticSize = Enum.AutomaticSize.X
					KeyBtn.BackgroundColor3 = sp._lib.Theme.Element
					KeyBtn.BorderSizePixel = 0
					KeyBtn.Text          = "[" .. tostring(default.Name or default):sub(1,6) .. "]"
					KeyBtn.TextColor3    = sp._lib.Theme.TextDim
					KeyBtn.FontFace      = Font
					KeyBtn.TextSize      = 11
					KeyBtn.AutoButtonColor = false
					KeyBtn.Parent        = SubFrame
					MakeCorner(KeyBtn, 4)
					MakeStroke(KeyBtn, sp._lib.Theme.Border2, 1)
					MakePadding(KeyBtn, 0, 0, 5, 5)

					Connect(KeyBtn.MouseButton1Click, function()
						picking = true
						KeyBtn.Text = "[...]"
					end)
					Connect(KeyBtn.InputBegan, function(i)
						if i.UserInputType == Enum.UserInputType.Touch then
							picking = true
							KeyBtn.Text = "[...]"
						end
					end)
					Connect(UserInputService.InputBegan, function(input)
						if not picking then
							if tostring(input.KeyCode) == tostring(key)
							or tostring(input.UserInputType) == tostring(key) then
								if mode == "Toggle" then
									toggled = not toggled
									pcall(callback, toggled)
								elseif mode == "Hold" then
									toggled = true
									pcall(callback, true)
								elseif mode == "Always" then
									pcall(callback, true)
								end
							end
							return
						end
						if input.KeyCode ~= Enum.KeyCode.Unknown then
							key     = input.KeyCode
						else
							key     = input.UserInputType
						end
						picking = false
						KeyBtn.Text = "[" .. tostring(key.Name or key):sub(1,6) .. "]"
						sp._lib.Flags[flag] = {Key = key, Mode = mode, Toggled = toggled}
						pcall(callback, toggled)
					end)
					Connect(UserInputService.InputEnded, function(input)
						if picking then return end
						if tostring(input.KeyCode) == tostring(key)
						or tostring(input.UserInputType) == tostring(key) then
							if mode == "Hold" then
								toggled = false
								pcall(callback, false)
							end
						end
					end)

					return self
				end

				return setmetatable({}, LabelMeta)
			end

			function SecMeta:Textbox(txData)
				txData   = txData or {}
				local flag     = txData.Flag or tostring(math.random(1e9))
				local default  = txData.Default or ""
				local numeric  = txData.Numeric or false
				local finished = txData.Finished or false
				local callback = txData.Callback or function() end
				local value    = default

				sp._lib.Flags[flag]    = value
				sp._lib.SetFlags[flag] = function(v)
					value = tostring(v)
					InputBox.Text       = value
					sp._lib.Flags[flag] = value
					pcall(callback, value)
				end

				local InputBox = New("TextBox")
				InputBox.Size          = U2(1, 0, 0, 26)
				InputBox.BackgroundColor3 = sp._lib.Theme.Element
				InputBox.BorderSizePixel = 0
				InputBox.Text          = default
				InputBox.TextColor3    = sp._lib.Theme.Text
				InputBox.PlaceholderText = txData.Placeholder or "..."
				InputBox.PlaceholderColor3 = sp._lib.Theme.TextDim
				InputBox.FontFace      = Font
				InputBox.TextSize      = 12
				InputBox.TextXAlignment= Enum.TextXAlignment.Left
				InputBox.ClearTextOnFocus = false
				InputBox.Parent        = ContentFrame
				MakeCorner(InputBox, 5)
				MakeStroke(InputBox, sp._lib.Theme.Border2, 1)
				MakePadding(InputBox, 0, 0, 8, 8)

				if finished then
					Connect(InputBox.FocusLost, function(enterPressed)
						if enterPressed then
							if numeric and not tonumber(InputBox.Text) then
								InputBox.Text = value
								return
							end
							value = InputBox.Text
							sp._lib.Flags[flag] = value
							pcall(callback, value)
						end
					end)
				else
					Connect(InputBox:GetPropertyChangedSignal("Text"), function()
						if numeric and not tonumber(InputBox.Text) and #InputBox.Text > 0 then
							InputBox.Text = value
							return
						end
						value = InputBox.Text
						sp._lib.Flags[flag] = value
						pcall(callback, value)
					end)
				end

				return {
					SetValue = function(_, v) sp._lib.SetFlags[flag](v) end,
					GetValue = function() return value end,
				}
			end

			return setmetatable({}, SecMeta)
		end

		return setmetatable(sp, SpMeta)
	end

	return setmetatable(page, PageMeta)
end

return Library
