			function SecMeta:Slider(sData)
				sData = sData or {}
				local flag     = sData.Flag or tostring(math.random(1e9))
				local min      = sData.Min     or 0
				local max      = sData.Max     or 100
				local default  = sData.Default or min
				local decimals = sData.Decimals or 1
				local suffix   = sData.Suffix  or ""
				local callback = sData.Callback or function() end
				local value    = default

				local function Round(n)
					if decimals < 1 then
						local m = 1 / decimals
						return math.floor(n * m + 0.5) / m
					end
					return math.floor(n + 0.5)
				end

				sp._lib.Flags[flag]    = value
				sp._lib.SetFlags[flag] = function(v)
					v = math.clamp(Round(v), min, max)
					value = v
					sp._lib.Flags[flag] = v
					local pct = (v - min) / (max - min)
					Tween(Fill,  {Size = U2(pct, 0, 1, 0)}, 0.1)
					Tween(Thumb, {Position = U2(pct, -4, 0.5, -4)}, 0.1)
					ValueLabel.Text = tostring(v) .. suffix
					pcall(callback, v)
				end

				local Wrap = New("Frame")
				Wrap.Size            = U2(1, 0, 0, 30)
				Wrap.BackgroundTransparency = 1
				Wrap.BorderSizePixel = 0
				Wrap.Parent          = ContentFrame

				local TopRow = New("Frame")
