if math.abs(d.X) > 8 or math.abs(d.Y) > 8 then return end
end
if press_canvas_x ~= nil then
if math.abs(scroll.CanvasPosition.X - press_canvas_x) > 4 then return end
end
if is_toggle then
if State.visible then hide_gui(false, false, false, true)
else show_gui(false) end
return
end
