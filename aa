function MusicVisualizer:start_animation()
if self.heartbeat_connection then return end
self.active = true
self.heartbeat_connection = RunService.Heartbeat:Connect(function(dt)
if not self.active or not self.container.Visible then return end
local time = tick()
self.current_intensity = self.current_intensity + (self.target_intensity - self.current_intensity) * dt * 3
for i, bar_data in ipairs(self.bars) do
local normalized
if self.music_playing then
local primary_wave = math.sin(time * bar_data.frequency * 2.2 + bar_data.phase)
local beat_sync = math.sin(time * 4.5 + i * 0.6)
local sub_harmonic = math.sin(time * bar_data.frequency * 0.7 + bar_data.secondary_phase) * 0.3
local noise = (math.sin(time * 17 + bar_data.noise_offset) * 0.5 + 0.5) * 0.15
local transient = math.abs(math.sin(time * 8.5 + bar_data.tertiary_phase)) * 0.2
local frequency_response = i <= 2 and 1.2 or (i >= 5 and 0.85 or 1.0)
local combined = (primary_wave * 0.4 + beat_sync * 0.35 + sub_harmonic + noise + transient) * frequency_response * bar_data.volatility
normalized = combined * 0.5 + 0.5
if math.random() < 0.015 * bar_data.volatility then
normalized = math.min(normalized + 0.3, 1.0)
end
else
local ambient_wave = math.sin(time * bar_data.frequency * 0.4 + bar_data.phase)
local slow_drift = math.sin(time * 0.8 + i * 0.7 + bar_data.secondary_phase)
local micro_flutter = math.sin(time * 3.5 + bar_data.tertiary_phase) * 0.15
local breath = math.sin(time * 0.6) * 0.1 + 0.9
local idle_response = i <= 2 and 0.9 or (i >= 5 and 0.7 or 0.8)
local combined = (ambient_wave * 0.5 + slow_drift * 0.3 + micro_flutter) * idle_response * breath
normalized = combined * 0.5 + 0.5
end
local height_range = self.max_height - self.min_height
local new_target = self.min_height + (normalized * height_range * self.current_intensity)
local spring_strength = self.music_playing and 18 or 10
local damping = self.music_playing and 0.85 or 0.75
local force = (new_target - bar_data.current_height) * spring_strength * dt
bar_data.velocity = (bar_data.velocity + force) * damping
bar_data.current_height = bar_data.current_height + bar_data.velocity
bar_data.current_height = math.clamp(bar_data.current_height, self.min_height, self.max_height)
bar_data.frame.Size = UDim2.new(0, 12, 0, bar_data.current_height)
local color
local height_ratio = (bar_data.current_height - self.min_height) / (self.max_height - self.min_height)
if self.rgb_mode_active and State.rgb_mode then
local rgb_hue = (State.rgb_hue or 0) % 360
local hue_spread = i * 30
local final_hue = (rgb_hue + hue_spread) % 360
local saturation = State.rgb_saturation or 0.9
local brightness_base = State.rgb_brightness or 0.8
local brightness_boost = height_ratio * 0.15
local glow_pulse = math.sin(time * 3 + i * 0.6) * 0.03
local brightness = math.clamp(brightness_base + brightness_boost + glow_pulse, 0.5, 0.98)
color = Color3.fromHSV(final_hue / 360, saturation, brightness)
else
local hue_base = (time * 0.15) % 1
local hue_offset = i * 0.18
local hue = (hue_base + hue_offset) % 1
local saturation = 0.9
local brightness_base = 0.8
local brightness_boost = height_ratio * 0.15
local glow_pulse = math.sin(time * 3 + i * 0.6) * 0.03
local brightness = math.clamp(brightness_base + brightness_boost + glow_pulse, 0.5, 0.98)
color = Color3.fromHSV(hue, saturation, brightness)
end
bar_data.frame.BackgroundColor3 = color
bar_data.glow.Color = color
bar_data.glow.Transparency = 0.3 - (height_ratio * 0.2)
local bright_color = Color3.fromHSV(color:ToHSV())
local h, s, v = color:ToHSV()
local dark_color = Color3.fromHSV(h, math.min(s * 1.1, 1), v * 0.7)
bar_data.gradient.Color = ColorSequence.new({
ColorSequenceKeypoint.new(0, bright_color),
ColorSequenceKeypoint.new(1, dark_color)
})
end
end)
