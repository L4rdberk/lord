end
local function lerp_color(c1, c2, alpha)
return Color3.new(
c1.R + (c2.R - c1.R) * alpha,
c1.G + (c2.G - c1.G) * alpha,
c1.B + (c2.B - c1.B) * alpha
)
end
local function ease_in_out_sine(t)
return -(math.cos(math.pi * t) - 1) / 2
end
local function ascend_cycle(cycle)
if cycle < 0.33 then
local t = cycle / 0.33
return 200 + (20 * t), 0.9 - (0.3 * t), 0.7 + (0.3 * t)
elseif cycle < 0.66 then
local t = (cycle - 0.33) / 0.33
return 220, 0.6 - (0.55 * t), 1
else
local t = (cycle - 0.66) / 0.34
return 220 - (20 * t), 0.05 + (0.85 * t), 1 - (0.3 * t)
end
end
local function get_rgb_color(mode, time, base_hue, element_index, element_info)
local hue = base_hue
local saturation = State.rgb_saturation
local brightness = State.rgb_brightness
local element_delay = State.rgb_element_delays[element_index] or 0
local is_stroke = element_info and element_info.is_stroke
local mode_handlers = {
wave = function()
local ripple = math.sin(time * 2 * State.rgb_speed - (element_index * 0.6))
hue = (base_hue + (ripple * 90) + (element_index * 20)) % 360
brightness = 0.6 + (ripple * 0.4)
saturation = 0.8 + (math.abs(ripple) * 0.2)
end,
breathing = function()
local breath = ease_in_out_sine((math.sin(time * 0.8 * State.rgb_speed) + 1) / 2)
saturation = 0.4 + (breath * 0.6)
brightness = 0.5 + (breath * 0.5)
hue = (base_hue + (breath * 30)) % 360
end,
music_sync = function()
if State.music_sound and State.music_sound.Playing then
local loudness = math.clamp(State.music_sound.PlaybackLoudness / 500, 0, 1)
brightness = 0.4 + (loudness * 0.6)
saturation = 0.6 + (loudness * 0.4)
hue = (base_hue * (1 + loudness * 3)) % 360
else
brightness = 0.3 + (((math.sin(time * 2) + 1) / 2) * 0.7)
end
end,
ascend_rgb = function()
local offset = is_stroke and 0 or (element_delay * 120)
local cycle = ((base_hue + offset) / 360) % 1
hue, saturation, brightness = ascend_cycle(cycle)
end,
neon = function()
local t = time * State.rgb_speed
local flicker = 0.85 + math.abs(math.sin(t * 7.3 + element_index)) * 0.15
local shift = (base_hue + element_index * 35 + math.sin(t * 1.5) * 25) % 360
hue = shift
saturation = 1
brightness = flicker
end,
ember = function()
local t = time * State.rgb_speed * 0.6
local heat = (math.sin(t + element_index * 0.4) + 1) / 2
hue = 10 + heat * 30
saturation = 0.9 + heat * 0.1
brightness = 0.55 + heat * 0.45
end,
}
local handler = mode_handlers[mode]
if handler then handler() end
return Color3.fromHSV(hue / 360, saturation, brightness)
end
