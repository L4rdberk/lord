end
end)
local function start_drag(inp)
if is_click_input(inp) then
if State.ui_dragging then return end
if State.prev_drag.dragging or State.cprev_drag.dragging then return end
State.ui_dragging = true
active_drag_input = inp
drag_start = inp.Position
start_pos = E.main.Position
State.has_moved_during_drag = false
pcall(function() CameraInput.setInputEnabled(false) end)
end
end
