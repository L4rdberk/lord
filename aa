-- Public API
local AscendUI = {}
AscendUI.Icons = Icons
AscendUI.Themes = Themes
AscendUI.C = C
AscendUI.Notify = Notify
AscendUI.create_toggle = create_toggle
AscendUI.create_button = create_button
AscendUI.create_slider = create_slider
AscendUI.apply_theme = apply_theme

function AscendUI.set_handler(name, fn)
E._handlers = E._handlers or {}
E._handlers[name] = fn
end

function AscendUI.init(config)
config = config or {}
if config.theme then apply_theme(config.theme) end
E.build()
E.setup_events()
E.build_nav_restore(E.screen1)
start_rgb_loop()
end

function AscendUI.add_to_tab(tab_id, build_fn)
local tab_info = {
main = E.main_content or E.content,
favorites = E.fav_content,
client = E.client_content,
animation = E.animation_content,
customize = E.customize_content,
settings = E.settings_content,
visuals = E.visuals_content,
font = E.font_content,
gardrobe = E.gardrobe_content,
misc = E.misc_content,
shop = E.shop_content,
fflags = E.fflags_content,
}
local scroll = tab_info[tab_id]
if scroll and build_fn then build_fn(scroll) end
end

function AscendUI.notify(msg, ntype, dur)
Notify.show(msg, ntype, dur)
end

function AscendUI.set_theme(name)
apply_theme(name)
end

function AscendUI.get_E()
return E
end

return AscendUI
